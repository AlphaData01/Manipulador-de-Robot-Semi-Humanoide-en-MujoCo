<mujoco model="Manipulador_Robotico_SemiHumanoide">

    <compiler
        angle="degree"
        meshdir="assets"
        autolimits="true"/>

    <option
        timestep="0.002"
        gravity="0 0 -9.81"
        integrator="implicitfast"
        iterations="30"/>

    <asset>

        <mesh
            name="bicep_collision_mesh"
            file="bicep_collision.stl"
            scale="0.001 0.001 0.001"/>

        <mesh
            name="antebrazo_collision_mesh"
            file="Antebrazo_colision.stl"
            scale="0.001 0.001 0.001"/>

    </asset>

    <worldbody>

        <!-- Piso fijo -->
        <geom
            name="piso"
            type="plane"
            size="2 2 0.1"
            rgba="0.75 0.75 0.75 1"/>

        <!--
        El bícep:
        -->
        <body
            name="bicep"
            pos="0 0 0.5"> <!-- 50cm de altura-->

            <freejoint/>

            <geom
                name="bicep_collision"
                type="mesh"
                mesh="bicep_collision_mesh"
                mass="0.5"
                rgba="0.8 0.2 0.2 1"/> <!--Color rojo-->

            <!--
            Cuerpo hijo antebrazo.
            -->
            <body
                name="antebrazo"
                pos="0.0241 0.2248 0">

                <joint
                    name="joint_motor"
                    type="hinge"
                    pos="0 0 0"
                    axis="0 0 1"
                    range="0 60"
                    damping="1"
                    armature="0.002"/>

                <!-- Este punto amarillo es el pivote real -->
                <site
                    name="eje_brazo"
                    type="cylinder"
                    pos="0 0 0"
                    size="0.0025 0.036 0.02"
                    rgba="1 1 0 1"/>

                <!-- La malla se acomoda alrededor del pivote -->
                <geom
                    name="antebrazo_collision"
                    type="mesh"
                    mesh="antebrazo_collision_mesh"
                    pos="0.002 -0.017 0"
                    euler="0 230 0"
                    mass="0.3"
                    rgba="0.2 0.4 0.9 1"/>

            </body>

        </body>

    </worldbody>

    <actuator>

        <position
            name="motor_brazo"
            joint="joint_motor"
            kp="20"
            ctrlrange="0 60"
            forcerange="-5 5"/>

    </actuator>

</mujoco>