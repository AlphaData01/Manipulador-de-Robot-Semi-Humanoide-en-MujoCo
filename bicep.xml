<mujoco model="Manipulador_Robotico_SemiHumanoide">

    <compiler
        angle="degree"
        meshdir="assets"
        autolimits="true"/>

    <option
        timestep="0.002"
        gravity="0 0 -9.81"
        integrator="implicitfast"
        iterations="30"/>

    <asset>

        <texture
            name="groundplane"
            type="2d"
            builtin="checker"
            rgb1="0.18 0.33 0.55"
            rgb2="0.28 0.46 0.70"
            width="512"
            height="512"/>

        <material
            name="groundplane"
            texture="groundplane"
            texrepeat="25 25"
            reflectance="0.25"/>

        <!-- Bíceps: colisión -->
        <mesh
            name="bicep_collision_mesh"
            file="bicep_colision.stl"
            scale="0.001 0.001 0.001"/>

        <!-- Bíceps: visual -->
        <mesh
            name="bicep_visual_mesh"
            file="bicep_visual.stl"
            scale="0.001 0.001 0.001"/>

        <!-- Antebrazo: colisión -->
        <mesh
            name="antebrazo_collision_mesh"
            file="Antebrazo_colision.stl"
            scale="0.001 0.001 0.001"/>

        <!-- Antebrazo: visual -->
        <mesh
            name="antebrazo_visual_mesh"
            file="Antebrazo_visual.stl"
            scale="0.001 0.001 0.001"/>

        <!-- Torso: colisión -->
        <mesh
            name="torso_collision_mesh"
            file="Torso_colision.stl"
            scale="0.001 0.001 0.001"/>

        <!-- Torso: visual -->
        <mesh
            name="torso_visual_mesh"
            file="Torso_visual.stl"
            scale="0.001 0.001 0.001"/>

        <!-- Hombro 1: colisión -->
        <mesh
            name="hombro_1_collision_mesh"
            file="Hombro_1_colision.stl"
            scale="0.001 0.001 0.001"/>

        <!-- Hombro 1: visual -->
        <mesh
            name="hombro_1_visual_mesh"
            file="Hombro_1_visual.stl"
            scale="0.001 0.001 0.001"/>

        <!-- Hombro 2: colisión -->
        <mesh
            name="hombro_2_collision_mesh"
            file="Hombro_2_colision.stl"
            scale="0.001 0.001 0.001"/>

        <!-- Hombro 2: visual -->
        <mesh
            name="hombro_2_visual_mesh"
            file="Hombro_2_visual.stl"
            scale="0.001 0.001 0.001"/>

    </asset>
    

    <worldbody>
        <!-- Escenario -->
        <light
            pos="0 0 4"
            dir="0 0 -1"
            directional="true"
            diffuse="0.6 0.6 0.6"
            specular="0.15 0.15 0.15"/>

        <!-- Piso fijo -->
        <geom
            name="piso"
            type="plane"
            size="5 5 0.1"
            material="groundplane"/>

        <!-- ================== Torso ================== -->
        <body
            name="torso"
            pos="0.30 0 0.25"
            euler="0 0 0">

            <!-- Malla visual del torso -->
            <geom
                name="torso_visual"
                type="mesh"
                mesh="torso_visual_mesh"
                pos="0 0 0.8782"
                euler="0 180 0"
                contype="0"
                conaffinity="0"
                density="0"
                rgba="0.85 0.85 0.88 1"/>

            <!-- Malla de colisión del torso -->
            <geom
                name="torso_collision"
                type="mesh"
                mesh="torso_collision_mesh"
                pos="0 0 0.8782"
                euler="0 180 0"
                rgba="0.55 0.55 0.30 0"/>

            <!-- ======== Hombro 1 ======== -->
            <body
                name="hombro_1"
                pos="0.1439 0.063 1.05485">

                <joint
                    name="joint_hombro_1"
                    type="hinge"
                    pos="0.0118 -0.024 -0.0094"
                    axis="0 1 0"
                    range="0 90"
                    damping="2"
                    armature="0.005"/>

                <!-- Marcador del eje real del hombro -->
                <site
                    name="eje_hombro_1"
                    type="cylinder"
                    pos="0.0118 -0.024 -0.0094"
                    euler="90 0 0"
                    size="0.0015 0.043"
                    rgba="1 1 0 1"/>

                <!-- STL de colisión del hombro -->
                <geom
                    name="hombro_1_collision"
                    type="mesh"
                    mesh="hombro_1_collision_mesh"
                    pos="0 0 0"
                    euler="90 0 270"
                    mass="0.20"
                    contype="0"
                    conaffinity="0"
                    rgba="0.15 0.65 0.25 0"/>
                
                    <!-- STL visual del hombro -->
                <geom
                    name="hombro_1_visual"
                    type="mesh"
                    mesh="hombro_1_visual_mesh"
                    pos="0 0 0"
                    euler="90 0 270"
                    contype="0"
                    conaffinity="0"
                    density="0"
                    rgba="0.15 0.15 0.18 1"/>

                <!-- ======== Hombro 2 ======== -->
                <body
                    name="hombro_2"
                    pos="-0.0007 -0.034 -0.002">

                    <joint
                        name="joint_hombro_2"
                        type="hinge"
                        pos="-0.01 0.0091 -0.045"
                        axis="1 0 0"
                        range="-180 30"
                        damping="2"
                        armature="0.005"/>

                    <!-- Marcador visual del segundo eje -->
                    <site
                        name="eje_hombro_2"
                        type="cylinder"
                        pos="-0.01 0.0091 -0.045"
                        euler="0 90 0"
                        size="0.004 0.043"
                        rgba="1 0.5 0 1"/>

                    <!-- Visual: esta se acomoda si aparece desfasada -->
                    <geom
                        name="hombro_2_visual"
                        type="mesh"
                        mesh="hombro_2_visual_mesh"
                        pos="0 0 0"
                        euler="270 0 90"
                        contype="0"
                        conaffinity="0"
                        density="0"
                        rgba="0.75 0.75 0.78 1"/>

                    <!-- STL de colisión del hombro 2 -->
                    <geom
                        name="hombro_2_collision"
                        type="mesh"
                        mesh="hombro_2_collision_mesh"
                        pos="0 0 0"
                        euler="270 0 90"
                        mass="0.20"
                        contype="1"
                        conaffinity="1"
                        rgba="0.2 0.4 0.9 0"/>

                    <!-- ================== Bíceps ================== -->
                    <body
                        name="bicep"
                        pos="-0.0513 -0.0369 -0.1095">

                        <!-- Rotación del brazo sobre el eje Z -->
                        <joint
                            name="joint_bicep_z"
                            type="hinge"
                            pos="-0.015 0.046 0.005"
                            axis="0 0 1"
                            range="-90 90"
                            damping="2"
                            armature="0.005"/>

                        <!-- Marcador del eje Z -0.015 -->
                        <site
                            name="eje_bicep_z"
                            type="cylinder"
                            pos="-0.015 0.046 0.005"
                            size="0.002 0.04"
                            rgba="1 0 1 1"/>

                        <!-- Malla visual del bíceps -->
                        <geom
                            name="bicep_visual"
                            type="mesh"
                            mesh="bicep_visual_mesh"
                            pos="0 0 0"
                            euler="270 270 0"
                            contype="0"
                            conaffinity="0"
                            density="0"
                            rgba="0.15 0.15 0.18 1"/>

                        <!-- Malla de colisión del bíceps -->
                        <geom
                            name="bicep_collision"
                            type="mesh"
                            mesh="bicep_collision_mesh"
                            pos="0 0 0"
                            euler="270 270 0"
                            mass="0.5"
                            contype="0"
                            conaffinity="0"
                            rgba="0.8 0.2 0.2 0"/>

                        <!-- ======= Antebrazo ======= -->
                        <body
                            name="antebrazo"
                            pos="-0.0327 0.10227 -0.2384">

                            <joint
                                name="joint_motor"
                                type="hinge"
                                pos="0.01 -0.0244 0.0136"
                                axis="-1 0 0"
                                range="0 90"
                                damping="2"
                                armature="0.005"/>

                            <site
                                name="eje_brazo"
                                type="cylinder"
                                pos="0.01 -0.0244 0.0136"
                                euler="0 90 0"
                                size="0.003 0.036"
                                rgba="1 1 0 1"/>

                            <!-- Malla visual del antebrazo -->
                            <geom
                                name="antebrazo_visual"
                                type="mesh"
                                mesh="antebrazo_visual_mesh"
                                pos="0 0 0"
                                euler="270 140 0"
                                contype="0"
                                conaffinity="0"
                                density="0"
                                rgba="0.75 0.75 0.78 1"/>

                            <geom
                                name="antebrazo_collision"
                                type="mesh"
                                mesh="antebrazo_collision_mesh"
                                pos="0 0 0"
                                euler="270 140 0"
                                contype="1"
                                conaffinity="1"
                                mass="0.3"
                                rgba="0.2 0.4 0.9 0"/>

                        </body>

                    </body>
                </body>

            </body>

        </body>


    </worldbody>

    <actuator>

        <!-- Motor del hombro -->
        <position
            name="motor_hombro_1"
            joint="joint_hombro_1"
            gear="57.2957795"
            kp="0.0061"
            ctrlrange="0 90"
            forcerange="-0.0873 0.0873"/>

        <position
            name="motor_hombro_2"
            joint="joint_hombro_2"
            gear="57.2957795"
            kp="0.0061"
            ctrlrange="-180 30"
            forcerange="-0.0873 0.0873"/>

        <position
            name="motor_bicep_z"
            joint="joint_bicep_z"
            gear="57.2957795"
            kp="0.0061"
            ctrlrange="-90 90"
            forcerange="-0.0873 0.0873"/>

        <!-- Motor actual del antebrazo -->
        <position
            name="motor_brazo"
            joint="joint_motor"
            gear="57.2957795"
            kp="0.0061"
            ctrlrange="0 90"
            forcerange="-0.0873 0.0873"/>

    </actuator>

</mujoco>